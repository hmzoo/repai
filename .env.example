# ============================================================================
# RepaI - Environment Variables Template
# ============================================================================
#
# This file shows which environment variables RepaI uses.
# It is SAFE to commit to git (contains NO sensitive data).
#
# To use:
# 1. Create a copy: cp .env.example .env
# 2. Edit .env with your actual values
# 3. Keep .env.example in git for documentation
# ============================================================================

# ──────────────────────────────────────────────────────────────────────────
# REQUIRED - LLM Configuration
# ──────────────────────────────────────────────────────────────────────────

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
# Required for: Iteration 2+ (auto-improvement)
OPENAI_API_KEY=sk-your-api-key-here

# ──────────────────────────────────────────────────────────────────────────
# OPTIONAL - Alternative LLM Providers
# ──────────────────────────────────────────────────────────────────────────

# Anthropic Claude API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini API Key
GOOGLE_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# OPTIONAL - Logging & Debug
# ──────────────────────────────────────────────────────────────────────────

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable debug mode for verbose output
DEBUG_MODE=true

# ──────────────────────────────────────────────────────────────────────────
# OPTIONAL - Database (for future versions)
# ──────────────────────────────────────────────────────────────────────────

# DATABASE_URL=postgresql://user:pass@localhost/repai
# DATABASE_NAME=repai

# ──────────────────────────────────────────────────────────────────────────
# OPTIONAL - External Services & Notifications
# ──────────────────────────────────────────────────────────────────────────

# Slack Webhook for notifications
# Get from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# GitHub Personal Access Token
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=

# Datadog API Key for monitoring
DATADOG_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# OPTIONAL - Agent Configuration (can also be in config.yaml)
# ──────────────────────────────────────────────────────────────────────────

# Agent name
AGENT_NAME=RepaI

# Maximum number of iterations (default: 10)
MAX_ITERATIONS=10

# Timeout per iteration in seconds (default: 300)
TIMEOUT_SECONDS=300

# ──────────────────────────────────────────────────────────────────────────
# NOTES
# ──────────────────────────────────────────────────────────────────────────
#
# Starting (.env):
#   • Keep it in .gitignore (excluded from version control)
#   • Contains REAL API keys and secrets
#   • NEVER share or commit!
#
# Template (.env.example):
#   • Safe to commit to git
#   • Shows what variables are available
#   • Contains NO sensitive data
#   • Used as reference for setup
#
# Loading Variables:
#   • Automatically loaded if python-dotenv installed
#   • Or manually: source .env
#   • Or in Python: os.getenv("OPENAI_API_KEY")
#
# Priority Order:
#   1. Environment variables (exported in shell)
#   2. .env file values
#   3. config.yaml defaults
#   4. Hard-coded defaults in code
#
# ──────────────────────────────────────────────────────────────────────────
